<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml for the ANCHOR phone companion (EMUI / Android).
  Replaces the HarmonyOS phone/src/main/module.json5.

  Key permissions:
    INTERNET + ACCESS_NETWORK_STATE — HMS services, AGConnect cloud functions
    BLUETOOTH_* — WearEngine watch communication
    SEND_SMS — direct emergency-contact SMS (no cloud round-trip needed on Android)
    POST_NOTIFICATIONS — show watch-disconnect alerts on Android 13+
    FOREGROUND_SERVICE* — keep WatchMonitorService alive while app is in background
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for HMS Push, WearEngine, AGConnect Cloud Functions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Bluetooth — required by WearEngine to detect and communicate with the watch -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <!-- Android 12+ Bluetooth permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />

    <!-- SMS for direct emergency-contact alerts on watch disconnect/ALERT state -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Post notifications (required at runtime on Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Keep WatchMonitorService running in the background between polls -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <application
        android:name=".AnchorApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Anchor">

        <!--
          Main activity — hosts the Jetpack Compose NavHost.
          Replaces EntryAbility.ets (HarmonyOS UIAbility).
          windowSoftInputMode=adjustResize ensures the keyboard doesn't cover text fields
          on the Contacts add-contact form.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          HMS Push Kit message receiver.
          Replaces PushAbility.ets (HarmonyOS PushExtensionAbility).
          Receives push messages from AGConnect cloud when the watch sends an alert.
          Must be registered with the exact action shown below.
        -->
        <service
            android:name=".services.AnchorMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.huawei.push.action.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>
</manifest>
